<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                                     https://hibernate.org/xsd/orm/mapping/mapping-3.1.0.xsd">

    <access>FIELD</access>

    <entity class="allmart.authservice.domain.customer.Customer">
        <table name="tbl_customer"/>
        <attributes>
            <basic name="email">
                <column name="email" nullable="false" unique="true"/>
            </basic>
            <basic name="encodedPassword">
                <column name="encoded_password" nullable="false"/>
            </basic>
            <basic name="name">
                <column name="name" nullable="false"/>
            </basic>
            <basic name="loginType">
                <column name="login_type" nullable="false"/>
                <enumerated>STRING</enumerated>
            </basic>
        </attributes>
    </entity>

    <entity class="allmart.authservice.domain.customer.SavedAddress">
        <table name="saved_address"/>
        <attributes>
            <many-to-one name="customer" fetch="LAZY" optional="false">
                <join-column name="customer_id" nullable="false" updatable="false"/>
            </many-to-one>
            <basic name="zipCode">
                <column name="zip_code" length="10"/>
            </basic>
            <basic name="roadAddress">
                <column name="road_address" length="200"/>
            </basic>
            <basic name="detailAddress">
                <column name="detail_address" length="200"/>
            </basic>
            <basic name="label">
                <column name="label" length="30"/>
            </basic>
            <basic name="isDefault">
                <column name="is_default" nullable="false"/>
            </basic>
        </attributes>
    </entity>

    <entity class="allmart.authservice.domain.member.Member">
        <table name="tbl_member"/>
        <attributes>
            <basic name="email">
                <column name="email" nullable="false" unique="true" updatable="false"/>
            </basic>
            <basic name="encodedPassword">
                <column name="encoded_password" nullable="false"/>
            </basic>
            <basic name="martName">
                <column name="mart_name" nullable="false"/>
            </basic>
            <basic name="role">
                <column name="role" nullable="false"/>
                <enumerated>STRING</enumerated>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
